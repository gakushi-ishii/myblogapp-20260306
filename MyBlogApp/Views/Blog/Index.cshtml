@model List<MyBlogApp.Models.BlogPost>
@{
    ViewData["Title"] = "ブログ記事一覧";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4">📝 My Blog</h1>
        <p class="lead text-muted">技術ブログ — 最新の記事をチェック</p>
    </div>

    <div class="row">
        @foreach (var post in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@post.Title</h5>
                        <p class="card-text text-muted flex-grow-1">@post.Summary</p>
                        <div class="mt-auto">
                            <div class="mb-2">
                                @foreach (var tag in post.Tags)
                                {
                                    <span class="badge bg-primary me-1">@tag</span>
                                }
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    <i>@post.Author</i> · @post.PublishedAt.ToString("yyyy/MM/dd")
                                </small>
                                <a asp-action="Detail" asp-route-id="@post.Id" class="btn btn-outline-primary btn-sm">
                                    続きを読む →
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
